rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 1. Artworks Domain
    match /artworks/{artworkId} {
      allow read: if true; // Publicly viewable
      allow create: if isAuthenticated() && request.resource.data.artistId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.artistId == request.auth.uid;
    }

    // 2. Events/Workshops Domain
    match /events/{eventId} {
      allow read: if true; // Publicly viewable
      allow create: if isAuthenticated() && request.resource.data.organizerId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.organizerId == request.auth.uid;
    }

    // 3. Collaborations Domain
    match /collaborations/{collabId} {
      allow read: if true; // Publicly viewable
      allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;
      
      // Applications subcollection
      match /applications/{appId} {
        allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || get(/databases/$(database)/documents/collaborations/$(collabId)).data.authorId == request.auth.uid);
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      }
    }

    // 4. Users & Private Data
    match /users/{userId} {
      allow read: if true; // Basic profile is public
      
      // Strict role enforcement on creation
      allow create: if isOwner(userId) 
                    && request.resource.data.role == 'observer'
                    && request.resource.data.keys().hasAll(['uid', 'role', 'createdAt']);
                    
      // Prevent users from escalating their own role or changing creation dates
      allow update: if isOwner(userId) 
                    && request.resource.data.role == resource.data.role
                    && request.resource.data.createdAt == resource.data.createdAt;
      
      // Private User Subcollections
      match /notifications/{notifId} {
        allow read: if isOwner(userId);
        allow write: if false; // System-only
      }
      
      match /transactions/{txId} {
        allow read: if isOwner(userId);
        allow write: if false; // System-only (recorded by secure actions/webhooks)
      }
      
      match /journal_entries/{entryId} {
        allow read: if true; // Artisan journal is public proof of process
        allow write: if isOwner(userId);
      }
    }

    // 5. Global Collection Group rules
    match /{path=**}/journal_entries/{entryId} {
       allow read: if true;
    }

    // 6. Global Notifications Collection - HARDENED
    match /notifications/{notifId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if false; // System-only/Backend-only
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // 7. RSVPs (Aliased correctly to event_rsvps)
    match /event_rsvps/{rsvpId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizerId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // 8. Global Deny-by-Default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
